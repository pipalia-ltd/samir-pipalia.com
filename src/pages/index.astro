---
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "@data/site";
import { formatPostDate, getLivePosts, postTitle, postUrl } from "@lib/posts";

const latestPosts = await getLivePosts(3);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    dateModified: "2026-05-18",
    mainEntity: {
      "@type": "Person",
      "@id": `${site.url}/#samir-pipalia`,
      name: site.name,
      url: site.url,
      sameAs: [site.linkedin],
      email: `mailto:${site.email}`,
      address: {
        "@type": "PostalAddress",
        addressLocality: "London",
        addressCountry: "GB",
      },
      jobTitle: "Head of Applications / ERP & Integration Leader",
      description: site.description,
      knowsAbout: [
        "SAP Business One",
        "ERP leadership",
        "Application strategy",
        "Enterprise integrations",
        "BPA TaskCentre",
        "Boyum",
        "SAP Concur",
        "Service Layer",
        "DI-API",
        "Microsoft SQL Server",
        "SAP HANA",
        "Shopify integration",
        "Schema.org structured data",
      ],
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "What does Samir Pipalia specialise in?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Samir Pipalia specialises in SAP Business One, ERP leadership, enterprise integrations, application stabilisation, support maturity, eCommerce integration and complex operational systems.",
        },
      },
      {
        "@type": "Question",
        name: "What senior roles is Samir Pipalia suited to?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Samir Pipalia is suited to roles such as Head of Applications, ERP Lead, SAP Business One Lead, Technical Applications Lead, Application Transformation Lead and interim applications leadership.",
        },
      },
    ],
  },
];
---

<BaseLayout title={site.title} description={site.description} canonical="/" ogType="profile" structuredData={structuredData}>
  <main id="main">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="eyebrow">London-based applications, ERP and integration leader</p>
        <h1 id="hero-title">I stabilise complex business systems and turn them into platforms for growth.</h1>
        <p class="hero-text">
          I am Samir Pipalia, a Head of Applications / ERP leader with 25+ years' experience across SAP Business One, integrations, automation, eCommerce and operational technology. I work best where the systems are important, messy and commercially exposed.
        </p>
        <div class="hero-actions" aria-label="Contact links">
          <a class="button primary" href={`mailto:${site.email}`}>Email Samir</a>
          <a class="button secondary" href={site.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn profile</a>
        </div>
      </div>
      <aside class="signal-panel" aria-label="Professional positioning">
        <div class="signal-top">
          <span class="status-dot" aria-hidden="true"></span>
          <span>Open to senior permanent, interim and contract roles</span>
        </div>
        <dl>
          <div>
            <dt>Target roles</dt>
            <dd>Head of Applications, ERP Lead, Technical Applications Lead, Application Transformation Lead</dd>
          </div>
          <div>
            <dt>Core systems</dt>
            <dd>SAP Business One, Boyum, BPA / TaskCentre, SAP Concur, SQL Server, SAP HANA</dd>
          </div>
          <div>
            <dt>Value</dt>
            <dd>Stabilisation, ownership, vendor challenge, integration delivery, support maturity</dd>
          </div>
        </dl>
        <img class="system-map" src="/assets/system-landscape.png" width="760" height="360" alt="Application landscape map connecting ERP, integrations, eCommerce and support maturity" decoding="async" />
      </aside>
    </section>

    <section class="section intro-band" aria-label="Professional summary">
      <p>
        Senior applications leader with a rare blend of hands-on technical depth, enterprise architecture, vendor management and commercial judgement. I have owned complex ERP landscapes across SAP Business One SQL and HANA, led upgrades and integrations, improved support maturity, and taken responsibility for incidents and programmes that needed calm delivery under pressure.
      </p>
    </section>

    <section class="section" id="work" aria-labelledby="work-title">
      <div class="section-heading">
        <p class="eyebrow">Evidence</p>
        <h2 id="work-title">What I am known for</h2>
      </div>
      <div class="proof-grid">
        <article class="proof-card">
          <span class="proof-number">38</span>
          <h3>SAP Business One companies stabilised</h3>
          <p>Stabilised a complex oil and gas ERP landscape across multiple business units and geographies for Prax Group through Sapphire Systems.</p>
        </article>
        <article class="proof-card">
          <span class="proof-number">25+</span>
          <h3>Years across applications and delivery</h3>
          <p>Built from developer roots into application strategy, ERP ownership, eCommerce, integrations, infrastructure and service leadership.</p>
        </article>
        <article class="proof-card">
          <span class="proof-number">5 sec</span>
          <h3>Report performance improvement</h3>
          <p>Redesigned Crystal Reports around stored procedures, reducing load times from over one minute to under five seconds.</p>
        </article>
        <article class="proof-card">
          <span class="proof-number">&pound;m</span>
          <h3>Growth-enabling systems</h3>
          <p>Helped Fast Key Services grow from roughly &pound;200k turnover into a multi-million-pound organisation by evolving its core systems.</p>
        </article>
      </div>
    </section>

    <section class="section case-section" id="case-studies" aria-labelledby="case-title">
      <div class="section-heading">
        <p class="eyebrow">Selected case studies</p>
        <h2 id="case-title">Specific problems I have solved</h2>
        <p>Clear problem, solution, outcome and technology context rather than generic claims.</p>
      </div>
      <div class="case-grid">
        <article class="case-card">
          <p class="case-meta">SAP Business One | Oil and gas | 38 companies</p>
          <h3>SAP Business One landscape stabilisation</h3>
          <p><strong>Problem:</strong> A complex oil and gas ERP estate needed stability across multiple SAP Business One companies, business units and geographies.</p>
          <p><strong>Outcome:</strong> Improved operational stability, issue ownership and process consistency across a high-risk ERP environment.</p>
          <a class="text-link" href="/sap-business-one-landscape-stabilisation.html">Read the SAP Business One stabilisation case study</a>
        </article>
        <article class="case-card">
          <p class="case-meta">Fuel cards | SAP B1 | MuleSoft | SQL</p>
          <h3>SAP Business One fuel card integration</h3>
          <p><strong>Problem:</strong> Downstream retail operations needed BP and Total fuel card acceptance connected into SAP Business One and surrounding systems.</p>
          <p><strong>Outcome:</strong> Enabled fuel card processing through a coordinated ERP and integration programme.</p>
          <a class="text-link" href="/sap-business-one-fuel-card-integration.html">Read the fuel card integration case study</a>
        </article>
        <article class="case-card">
          <p class="case-meta">Aviation invoicing | IATA XML | SAP B1</p>
          <h3>IATA-compliant aviation invoicing</h3>
          <p><strong>Problem:</strong> Aviation invoicing needed standards-compliant XML output aligned with operational and regulatory expectations.</p>
          <p><strong>Outcome:</strong> Delivered business-critical IATA-compliant invoicing capability.</p>
        </article>
        <article class="case-card">
          <p class="case-meta">Shopify | SAP Business One | B2B commerce</p>
          <h3>Shopify to SAP Business One integration</h3>
          <p><strong>Problem:</strong> B2B eCommerce orders needed reliable flow into SAP Business One without excessive manual processing.</p>
          <p><strong>Outcome:</strong> Reduced operational friction and improved supportability for eCommerce order handling.</p>
          <a class="text-link" href="/shopify-sap-business-one-integration.html">Read the Shopify SAP Business One case study</a>
        </article>
      </div>
    </section>

    <section class="section latest-writing" id="writing" aria-labelledby="writing-title">
      <div class="section-heading">
        <p class="eyebrow">Latest writing</p>
        <h2 id="writing-title">Practical notes from the application front line</h2>
        <p>Daily posts on SAP Business One, ERP ownership, integration, support maturity and application leadership.</p>
      </div>
      <div class="post-list">
        {
          latestPosts.length > 0 ? (
            latestPosts.map((post) => (
              <article class="post-card">
                <div class="post-meta">
                  <time datetime={post.data.publish_at.toISOString()}>{formatPostDate(post.data.publish_at)}</time>
                </div>
                <h3><a href={postUrl(post)}>{postTitle(post)}</a></h3>
                <p>{post.data.excerpt || post.data.description}</p>
              </article>
            ))
          ) : (
            <article class="post-card">
              <h3>Writing starts here</h3>
              <p>New posts will appear here automatically once they reach their scheduled publish time.</p>
            </article>
          )
        }
      </div>
      <p><a class="text-link" href="/blog/">Read the blog</a></p>
    </section>

    <section class="section split" id="experience" aria-labelledby="experience-title">
      <div class="section-heading">
        <p class="eyebrow">Experience</p>
        <h2 id="experience-title">Recent leadership and delivery</h2>
      </div>
      <div class="timeline">
        <article><p class="period">2025 - 2026</p><h3>Kinly - SAP Business One Application Manager</h3><p>Supported a multi-country SAP Business One landscape across UK, USA, Germany, Switzerland, India, Singapore, Norway and Benelux. Acted as L3 escalation, led upgrades and delivered B2B eCommerce integration between Shopify and SAP Business One.</p></article>
        <article><p class="period">2024</p><h3>KAI Consulting - SAP Business One Consultant</h3><p>Delivered SAP Business One upgrade from v9.3 to v10, including Service Layer, SSL, licensing and localisation strategy.</p></article>
        <article><p class="period">2022 - 2023</p><h3>Sapphire Systems / Prax Group - ERP & Integration Lead</h3><p>Owned ERP and integration delivery across SAP Business One, Boyum, Crystal Reports, BPA automation and related integrations.</p></article>
        <article><p class="period">2021 - 2022</p><h3>Clubhouse Golf - SAP Business One HANA Technical Lead</h3><p>Brought in before go-live to stabilise a challenging SAP Business One HANA implementation.</p></article>
        <article><p class="period">2005 - 2020</p><h3>Fast Key Services - ERP & Integration Lead / Senior Developer</h3><p>Architected and evolved the technology landscape behind a growing eCommerce and operations business.</p></article>
      </div>
    </section>

    <section class="section projects-section" id="projects" aria-labelledby="projects-title">
      <div class="section-heading">
        <p class="eyebrow">Additional projects & publications</p>
        <h2 id="projects-title">Evidence beyond the CV</h2>
      </div>
      <div class="projects-grid">
        <article class="project-card"><p class="case-meta">AI prototype | Google Gemma 2 Hackathon | 2024</p><h3>Image recognition shopping prototype</h3><p>Contributed to an AI-powered image recognition prototype built during a three-day sprint.</p></article>
        <article class="project-card"><p class="case-meta">PwC US | Sage Accounts 50 | Integration</p><h3>Bespoke Sage Accounts 50 integration</h3><p>Delivered a custom Sage Accounts 50 integration for PricewaterhouseCoopers (US).</p></article>
        <article class="project-card"><p class="case-meta">Technical publication | IBM Notes / XPages</p><h3>Keeping data separate from XPages design</h3><p>Published technical guidance on separating data from XPages design.</p></article>
      </div>
    </section>

    <section class="section capabilities" id="skills" aria-labelledby="capabilities-title">
      <div class="section-heading">
        <p class="eyebrow">Capability map</p>
        <h2 id="capabilities-title">Where I can lead</h2>
      </div>
      <div class="capability-grid">
        <div><h3>Applications & ERP</h3><p>SAP Business One SQL and HANA, upgrades, localisation, finance/logistics/admin, application ownership and roadmap management.</p></div>
        <div><h3>Integration & Automation</h3><p>BPA / TaskCentre, DI-API, Service Layer, REST/SOAP APIs, XML, JSON, MuleSoft collaboration and data flow reliability.</p></div>
        <div><h3>Operations & Support</h3><p>L3 escalation, root cause analysis, service desk enablement, vendor management, training and high-accountability issue ownership.</p></div>
        <div><h3>Digital Commerce</h3><p>Shopify integration, bespoke eCommerce, Google Shopping, content systems, fulfilment APIs, SEO and Schema.org structured data.</p></div>
      </div>
    </section>

    <section class="section faq-section" id="faq" aria-labelledby="faq-title">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2 id="faq-title">Quick answers for recruiters and AI search</h2>
      </div>
      <div class="faq-list">
        <article><h3>What does Samir Pipalia specialise in?</h3><p>SAP Business One, ERP leadership, application strategy, integrations, automation, eCommerce systems, service improvement and complex application stabilisation.</p></article>
        <article><h3>Does Samir Pipalia work hands-on or only strategically?</h3><p>Both. His value is the combination of hands-on technical depth, architecture judgement, stakeholder management, vendor challenge and senior ownership.</p></article>
      </div>
    </section>

    <section class="section contact-section" id="contact" aria-labelledby="contact-title">
      <div>
        <p class="eyebrow">Contact</p>
        <h2 id="contact-title">Useful when systems need ownership.</h2>
        <p>I am open to senior applications, ERP, integration and technical leadership roles in the UK market, including permanent, interim and contract opportunities.</p>
      </div>
      <div class="contact-actions">
        <a class="button primary" href={`mailto:${site.email}`}>{site.email}</a>
        <a class="button secondary" href={site.linkedin} target="_blank" rel="noopener noreferrer">linkedin.com/in/pipalia</a>
      </div>
    </section>
  </main>
</BaseLayout>

---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { site } from "@data/site";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogType?: "website" | "profile" | "article";
  image?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = site.title,
  description = site.description,
  canonical = Astro.url.pathname,
  ogType = "website",
  image = site.ogImage,
  structuredData,
} = Astro.props;

const canonicalUrl = new URL(canonical, site.url).toString();
const imageUrl = new URL(image, site.url).toString();
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#f7f8f3" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Samir Pipalia Blog" href="/rss.xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${site.analyticsId}`}></script>
    <script is:inline define:vars={{ analyticsId: site.analyticsId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', analyticsId);
    </script>
    {
      structuredData && (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
      )
    }
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
